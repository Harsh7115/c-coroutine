# EditorConfig — https://editorconfig.org
root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# C source and headers
[*.{c,h}]
indent_style = space
indent_size = 4

# Assembly
[*.S]
indent_style = tab
tab_width = 8

# YAML (GitHub Actions workflows)
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Makefile requires tabs
[Makefile]
indent_style = tab
tab_width = 4
